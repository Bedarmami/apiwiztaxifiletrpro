<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp"
    tools:background="#33000000">

    <!-- Основной контейнер с закругленными углами -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardContainer"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- КАРТА (ФОН) - ОГРАНИЧИВАЕМ ВЫСОТУ -->
            <FrameLayout
                android:id="@+id/mapContainer"
                android:layout_width="match_parent"
                android:layout_height="130dp">

                <org.osmdroid.views.MapView
                    android:id="@+id/mapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- ГРАДИЕНТ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/overlay_gradient_dark" />

                <!-- ТАЙМЕР -->
                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:background="#99000000"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="10s"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <!-- КНОПКА ЗАКРЫТИЯ (НА КАРТЕ) -->
                <ImageButton
                    android:id="@+id/btnClose"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="35dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/circle_button_bg"
                    android:padding="5dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#FFFFFF" />

                <!-- КНОПКА НАВИГАЦИИ -->
                <ImageButton
                    android:id="@+id/btnNavigate"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="6dp"
                    android:background="@drawable/circle_button_bg"
                    android:src="@android:drawable/ic_menu_directions"
                    android:visibility="gone" />

                <!-- КНОПКА 🐞 ОТЧЁТ ОБ ОШИБКЕ -->
                <TextView
                    android:id="@+id/btnBugReport"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="6dp"
                    android:background="@drawable/circle_button_bg"
                    android:gravity="center"
                    android:text="🐞"
                    android:textSize="16sp"
                    android:visibility="visible" />

            </FrameLayout>

            <!-- ГАРМОШКА ИНФОРМАЦИИ (ВЕРТИКАЛЬНО И ПЛОТНО) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:id="@+id/statsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvHourlyRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="200"
                        android:textColor="#00FF7F"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" zł/ч"
                        android:textColor="#AAFFFFFF"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvAppName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#00BFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChainWarning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFD700"
                            android:textSize="9sp"
                            android:visibility="gone"
                            tools:text="⚠️ В ЦЕПОЧКЕ"
                            tools:visibility="visible" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/routeRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="15.0 km" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" • "
                        android:textColor="#44FFFFFF"/>
                    <TextView
                        android:id="@+id/tvMinutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="258 min" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="4"
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp"
                    tools:text="A: Warszawa, Chmielna 10\nB: Warszawa, Aleja Niepodległości 159" />

                <!-- Глоу (Свечение) теперь внутри контента -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">
                    
                    <View
                        android:id="@+id/vVerdictGlow"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="#00000000" />

                    <TextView
                        android:id="@+id/tvVerdict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="6dp"
                        android:textColor="#00FF7F"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="✅ ХОРОШИЙ ЗАКАЗ" />
                </FrameLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:id="@+id/tvColleagues"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥 0"
                        android:textColor="#44FFFFFF"
                        android:textSize="8sp" />
                    <TextView
                        android:id="@+id/tvSyncStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="☁️ SYNC"
                        android:textColor="#00FF7F"
                        android:textSize="8sp" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
